@page
@model Pharmacy_order_system.Pages.Admin.OrdersModel
@{
    ViewData["Title"] = "All Orders";
}
<h2 class="mb-3">Customer Orders</h2>
@if (Model.Orders.Count == 0)
{
    <div class="alert alert-info">No orders available.</div>
}
else
{
    @foreach (var order in Model.Orders)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <h5>Order #@order.OrderId</h5>
                    <span>@order.Date.ToLocalTime()</span>
                </div>
                <p class="mb-2">Customer: <strong>@order.User?.Name</strong> (@order.User?.Email)</p>
                <table class="table table-sm">
                    <thead><tr><th>Medicine</th><th>Qty</th><th>Price</th></tr></thead>
                    <tbody>
                    @foreach (var item in order.OrderItems)
                    {
                        <tr>
                            <td>@item.Medicine?.Name</td>
                            <td>@item.Quantity</td>
                            <td>?@item.Price</td>
                        </tr>
                    }
                    </tbody>
                </table>
                <div class="text-end fw-bold">Total: ?@order.TotalAmount</div>
            </div>
        </div>
    }
}
