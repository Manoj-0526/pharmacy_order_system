@page
@model Pharmacy_order_system.Pages.Prescriptions.UploadModel
@{
    ViewData["Title"] = "Prescription Upload";
}
<h2 class="mb-3">Upload Prescription</h2>
@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}
<form method="post" enctype="multipart/form-data" class="card card-body mb-4">
    <input type="hidden" asp-for="FromCart" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Prescription File (jpg/png/pdf)</label>
        <input asp-for="PrescriptionFile" type="file" class="form-control" />
        <span asp-validation-for="PrescriptionFile" class="text-danger"></span>
    </div>
    <button class="btn btn-warning" type="submit">Upload</button>
</form>

<h4>Your Uploads</h4>
<table class="table table-striped">
    <thead>
        <tr>
            <th>File</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model.Prescriptions)
    {
        <tr>
            <td><a href="@p.FilePath" target="_blank">View Prescription</a></td>
            <td>
                <span class="badge @(p.Status == PrescriptionStatus.Approved ? "bg-success" : p.Status == PrescriptionStatus.Rejected ? "bg-danger" : "bg-secondary")">
                    @p.Status
                </span>
            </td>
        </tr>
    }
    </tbody>
</table>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
