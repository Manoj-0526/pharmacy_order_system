@page
@model Pharmacy_order_system.Pages.Pharmacist.PrescriptionsModel
@{
    ViewData["Title"] = "Prescription Review";
}
<h2 class="mb-3">Prescription Review</h2>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Customer</th>
            <th>File</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model.Prescriptions)
    {
        <tr>
            <td>@p.User?.Name (@p.User?.Email)</td>
            <td>
                @if (!string.IsNullOrWhiteSpace(p.FilePath))
                {
                    <a href="@Url.Content(p.FilePath)" target="_blank" rel="noopener noreferrer">Open File</a>
                }
                else
                {
                    <span class="text-muted">No file</span>
                }
            </td>
            <td>@p.Status</td>
            <td>
                @if (p.Status == PrescriptionStatus.Pending)
                {
                    <form method="post" asp-page-handler="Update" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@p.PrescriptionId" />
                        <button class="btn btn-sm btn-success" type="submit" name="status" value="Approved">Approve</button>
                        <button class="btn btn-sm btn-danger" type="submit" name="status" value="Rejected">Reject</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
